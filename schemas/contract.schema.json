{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FatherHale/HaleES-Architecture/schemas/contract.schema.json",
  "title": "HaleES Public Contract Shape",
  "description": "Public schema for the visible shape of a governed contract. This is not the private HaleES production contract engine.",
  "type": "object",
  "required": [
    "contract_id",
    "version",
    "domain",
    "risk_level",
    "objective",
    "context",
    "authority_boundary",
    "required_output",
    "acceptance_criteria",
    "grading_target",
    "iteration_rules"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object"
    },
    "authority_boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_output": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "grading_target": {
      "type": "object",
      "required": [
        "rubric",
        "threshold_global_score",
        "binary_pass_rule",
        "confidence_tracking"
      ],
      "properties": {
        "rubric": {
          "type": "string",
          "minLength": 1
        },
        "threshold_global_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "binary_pass_rule": {
          "type": "string",
          "minLength": 1
        },
        "confidence_tracking": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "iteration_rules": {
      "type": "object",
      "required": [
        "max_iterations",
        "failure_behavior",
        "stop_condition_pass",
        "stop_condition_fail"
      ],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "failure_behavior": {
          "type": "string",
          "minLength": 1
        },
        "stop_condition_pass": {
          "type": "string",
          "minLength": 1
        },
        "stop_condition_fail": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "public_boundary_note": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
